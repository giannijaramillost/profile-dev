{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!@vite|@react-refresh|src|node_modules|assets|favicon.svg|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}